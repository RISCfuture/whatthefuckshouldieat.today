{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "project": ["src/**/*.{ts,vue}"],
  "entry": ["src/**/*.spec.ts", "vitest.setup.ts", "cypress/**/*.{ts,js}"],
  "ignore": ["vitest.config.ts"],
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": [
    "vite",
    "run-p",
    "vitest",
    "cypress",
    "start-server-and-test",
    "vue-tsc",
    "eslint",
    "stylelint",
    "oxlint",
    "knip",
    "prettier"
  ],
  "ignoreDependencies": [
    "eslint",
    "jiti",
    "npm-run-all2",
    "oxlint",
    "start-server-and-test",
    "stylelint",
    "vue-eslint-parser",
    "vue-tsc"
  ],
  "rules": {
    "exports": "warn"
  }
}
