{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "project": ["src/**/*.{ts,vue}"],
  "entry": ["src/main.ts", "src/**/*.spec.ts", "vitest.setup.ts", "e2e/**/*.{ts,js}"],
  "vite": false,
  "vitest": false,
  "ignoreExportsUsedInFile": true,
  "ignoreBinaries": [
    "vite",
    "run-p",
    "vitest",
    "playwright",
    "vue-tsc",
    "eslint",
    "stylelint",
    "oxlint",
    "knip",
    "prettier"
  ],
  "ignoreDependencies": [
    "eslint",
    "jiti",
    "npm-run-all2",
    "oxlint",
    "stylelint",
    "vue-eslint-parser",
    "vue-tsc",
    "@vitejs/plugin-vue",
    "jsdom",
    "vite-plugin-csp-guard",
    "vite-plugin-pwa",
    "vite-plugin-vue-devtools"
  ],
  "rules": {
    "exports": "warn"
  }
}
