  "type": "module",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --ui",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint:eslint": "eslint .",
    "lint:stylelint": "stylelint \"src/**/*.{css,vue}\"",
    "lint:oxlint": "oxlint -c oxlintrc.json src",
    "lint:knip": "knip",
    "lint": "yarn lint:eslint && yarn lint:stylelint && yarn lint:oxlint && yarn lint:knip",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fontsource/noticia-text": "^5.2.8",
    "@fontsource/poetsen-one": "^5.2.7",
    "@sentry/vue": "^10.53.1",
    "@vueuse/core": "^14.3.0",
    "date-fns": "^4.2.1",
    "lodash-es": "^4.18.1",
    "normalize.css": "^8.0.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.60.0",
    "@testing-library/vue": "^8.1.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.14.1",
    "npm-run-all2": "^9.0.0",
    "oxlint": "^1.66.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.13",
    "vite-plugin-csp-guard": "^4.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^10.4.0",
